{
  "name": "@puresignal/essl",
  "version": "0.1.1",
  "description": "Algorithmic composition library",
  "keywords": [
    "algorithmic-composition",
    "creative-coding",
    "audio",
    "music",
    "generative"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": "https://github.com/puresignaldev/essl",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --emitDeclarationOnly && bun build ./src/index.ts --outdir ./dist --target node",
    "build:docs": "typedoc",
    "test": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.5.3",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "vitest": "^4.1.0"
  }
}
